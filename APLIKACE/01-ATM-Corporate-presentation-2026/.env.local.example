# Heslo pro přihlášení do admin panelu /admin
ADMIN_PASSWORD=zvolte-si-heslo

# GitHub Personal Access Token (scope: repo)
# Vygeneruj na: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Název repozitáře ve formátu uzivatel/repo
GITHUB_REPO=PavlinaParizkova/Interni-aplikace

# Větev repozitáře
GITHUB_BRANCH=main
