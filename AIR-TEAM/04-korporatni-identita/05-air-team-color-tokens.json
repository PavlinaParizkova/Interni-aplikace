    "applicationMatrix": {
      "id": "2.4",
      "title": "Aplikační matice barev (Color Application Matrix)",
      "purpose": "Pravidla pro kombinaci podkladových barev a korporátních prvků pro čitelnost a konzistenci v tisku, digitálu a polepech.",
      "variants": [
        {
          "id": "primary-light",
          "name": "Primární varianta (světlý podklad)",
          "usage": "Výchozí pro veškerou úřední korespondenci a bílé tiskoviny.",
          "background": {
            "label": "AIR TEAM White",
            "tokenRef": "color.core.white",
            "hex": "#ffffff"
          },
          "elements": {
            "description": "Plnobarevné logo a text: AIR TEAM Blue + AIR TEAM Red.",
            "logoText": [
              { "label": "AIR TEAM Blue", "tokenRef": "color.core.blue", "hex": "#153151" },
              { "label": "AIR TEAM Red", "tokenRef": "color.core.red", "hex": "#d51c17" }
            ]
          }
        },
        {
          "id": "inverse-red-accent",
          "name": "Inverzní varianta s červeným akcentem (kombinovaný podklad)",
          "usage": "Marketingové materiály, letáky, digitální bannery s červenou na tmavém pozadí.",
          "background": {
            "label": "AIR TEAM Blue V1",
            "tokenRef": "color.blueVariants.v1",
            "hex": "#10253e",
            "restriction": "Výhradně tento podklad – ne obecná tmavě modrá bez V1."
          },
          "elements": {
            "description": "Červené části loga (křídla) nebo zvýrazněný text – standardní AIR TEAM Red.",
            "accent": { "label": "AIR TEAM Red", "tokenRef": "color.core.red", "hex": "#d51c17" },
            "rationale": "Odstín V1 (CMYK 100/80/40/57) dává dostatečný jasový kontrast, aby červená nezanikla; u základní tmavě modré to nelze spolehlivě zajistit."
          }
        },
        {
          "id": "high-contrast-blue-white",
          "name": "High-contrast varianta (pouze modrá a bílá)",
          "usage": "Technická dokumentace, certifikace (Part 21J, 21G, 145), kde není žádoucí červený akcent.",
          "background": {
            "label": "Nejtmavší AIR TEAM Blue",
            "tokenRef": "color.core.blue",
            "hex": "#153151"
          },
          "elements": {
            "description": "Texty a loga v bílé nebo ve světlých odstínech šedé Black V3 / V4.",
            "allowed": [
              { "label": "AIR TEAM White", "tokenRef": "color.core.white", "hex": "#ffffff" },
              { "label": "Black V3", "tokenRef": "color.blackVariants.v3", "hex": "#d0d0d0" },
              { "label": "Black V4", "tokenRef": "color.blackVariants.v4", "hex": "#e3e3e3" }
            ],
            "restriction": "V této konfiguraci je zakázáno používat korporátní červenou (nízký kontrast)."
          }
        }
      ]
    },
    "productionSpecs": {
      "title": "Shrnutí technických hodnot pro výrobu (tisk / digitál)",
      "rows": [
        {
