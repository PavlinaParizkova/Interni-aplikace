          "cmyk": { "c": 100, "m": 80, "y": 40, "k": 57 },
          "cmykString": "100 / 80 / 40 / 57",
          "rgb": { "r": 16, "g": 37, "b": 62 },
          "tokenRef": "color.blueVariants.v1"
        },
        {
          "prvek": "Korporátní červená",
          "hex": "#d51c17",
          "cmyk": { "c": 9, "m": 98, "y": 100, "k": 1 },
          "cmykString": "9 / 98 / 100 / 1",
          "rgb": { "r": 213, "g": 28, "b": 23 },
          "tokenRef": "color.core.red"
        }
